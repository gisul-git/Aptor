#!/bin/bash
#
# Post-installation script for aicompetency-agent Debian package
#
# This script runs after package installation and:
# 1. Creates necessary directories
# 2. Sets proper permissions
# 3. Installs and enables systemd user service
# 4. Starts the service
#
# This script is called automatically by dpkg during package installation.

set -e  # Exit on error

AGENT_NAME="aicompetency-agent"
AGENT_BIN="/usr/bin/${AGENT_NAME}"
SERVICE_NAME="${AGENT_NAME}.service"
SERVICE_FILE="/usr/lib/systemd/user/${SERVICE_NAME}"
AGENT_DIR="/var/lib/${AGENT_NAME}"
LOG_DIR="/var/log/${AGENT_NAME}"

echo "AI Competency Agent - Post-installation setup"
echo "=============================================="

# Create directories
echo "Creating directories..."
mkdir -p "$AGENT_DIR"
mkdir -p "$LOG_DIR"
mkdir -p "$AGENT_DIR/uploads"
mkdir -p "/usr/lib/systemd/user"

# Set permissions
echo "Setting permissions..."
chmod 755 "$AGENT_BIN"
chmod 755 "$AGENT_DIR"
chmod 755 "$LOG_DIR"
chown -R root:root "$AGENT_DIR" "$LOG_DIR" 2>/dev/null || true

# Check if agent binary exists
if [ ! -f "$AGENT_BIN" ]; then
    echo "ERROR: Agent binary not found at $AGENT_BIN"
    exit 1
fi

# Check if service file exists
if [ ! -f "$SERVICE_FILE" ]; then
    echo "ERROR: Service file not found at $SERVICE_FILE"
    exit 1
fi

# Reload systemd to pick up new service
echo "Reloading systemd..."
systemctl --user daemon-reload 2>/dev/null || systemctl daemon-reload

# Enable service for all users (user service)
echo "Enabling service..."
# For user services, we need to enable for each user
# This is a limitation - user services can't be enabled system-wide
# We'll create a symlink in the user's systemd directory

# Try to enable for current user if we can determine it
if [ -n "$SUDO_USER" ]; then
    USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
    USER_SYSTEMD_DIR="$USER_HOME/.config/systemd/user"
    mkdir -p "$USER_SYSTEMD_DIR"
    
    # Create symlink to service file
    if [ -f "$SERVICE_FILE" ]; then
        ln -sf "$SERVICE_FILE" "$USER_SYSTEMD_DIR/${SERVICE_NAME}"
        systemctl --user --global daemon-reload 2>/dev/null || true
        echo "Service enabled for user: $SUDO_USER"
    fi
else
    echo "WARNING: Could not determine user. Service must be enabled manually."
    echo "To enable for a user, run:"
    echo "  systemctl --user enable $SERVICE_NAME"
    echo "  systemctl --user start $SERVICE_NAME"
fi

# Start service if we have a user
if [ -n "$SUDO_USER" ]; then
    echo "Starting service..."
    # Note: We can't directly start a user service from postinst
    # The user will need to start it after login, or we can use a different approach
    echo "Service will start automatically when user logs in."
    echo "To start immediately, run (as the user):"
    echo "  systemctl --user start $SERVICE_NAME"
fi

echo ""
echo "Installation complete!"
echo "===================="
echo "Agent binary: $AGENT_BIN"
echo "Agent directory: $AGENT_DIR"
echo "Service file: $SERVICE_FILE"
echo ""
echo "WebSocket server: ws://127.0.0.1:8889"
echo ""
echo "To enable and start the service for a user:"
echo "  systemctl --user enable $SERVICE_NAME"
echo "  systemctl --user start $SERVICE_NAME"
echo ""
echo "To check service status:"
echo "  systemctl --user status $SERVICE_NAME"
echo ""
echo "To view logs:"
echo "  journalctl --user -u $SERVICE_NAME -f"
echo ""

exit 0
